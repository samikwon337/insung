FROM node:20-alpine

RUN apk add --no-cache openjdk21-jre-headless curl bash

# Firebase CLI 설치
RUN npm install -g firebase-tools

WORKDIR /app

COPY firebase.json .firebaserc firestore.rules storage.rules ./

# 에뮬레이터 바이너리 사전 다운로드 (빌드 시 캐싱)
RUN firebase setup:emulators:firestore && \
    firebase setup:emulators:storage && \
    firebase setup:emulators:ui

EXPOSE 4000 8080 9099 9199

CMD ["firebase", "emulators:start", "--project", "demo-pms"]
