[debug] [2026-03-23T14:54:17.580Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-pms:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // 로그인한 사용자만 접근 가능\n    function isAuthenticated() {\n      return request.auth != null;\n    }\n\n    // 본인 여부\n    function isOwner(uid) {\n      return request.auth.uid == uid;\n    }\n\n    // 역할 조회 (users 컬렉션에서)\n    function getRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    function isHrAdmin() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isHrAdmin == true; }\n    function isCeo()     { return getRole() == 'CEO'; }\n    function isExec()    { return getRole() == 'EXECUTIVE'; }\n    function isLead()    { return getRole() == 'TEAM_LEAD'; }\n    function isMember()  { return getRole() == 'MEMBER'; }\n\n    // 사용자\n    match /users/{uid} {\n      allow read: if isAuthenticated();\n      allow write: if isOwner(uid) || isHrAdmin() || isCeo();\n    }\n\n    // 조직\n    match /organizations/{orgId} {\n      allow read: if isAuthenticated();\n      allow write: if isHrAdmin() || isCeo();\n    }\n\n    // 목표\n    match /goals/{goalId} {\n      allow read: if isAuthenticated();\n      allow create: if isAuthenticated() &&\n        request.resource.data.userId == request.auth.uid;\n      allow update: if isAuthenticated() && (\n        resource.data.userId == request.auth.uid ||\n        isLead() || isExec() || isCeo() || isHrAdmin()\n      );\n    }\n\n    // 목표 이력 (읽기 전용)\n    match /goalHistories/{id} {\n      allow read: if isAuthenticated();\n      allow create: if isAuthenticated();\n    }\n\n    // 진행상황\n    match /progressUpdates/{id} {\n      allow read: if isAuthenticated();\n      allow create: if isAuthenticated() &&\n        request.resource.data.userId == request.auth.uid;\n    }\n\n    // 1on1\n    match /oneOnOnes/{id} {\n      allow read: if isAuthenticated();\n      allow write: if isAuthenticated() && (\n        resource == null ||\n        resource.data.leaderId == request.auth.uid ||\n        resource.data.memberId == request.auth.uid\n      );\n    }\n\n    // 조직 평가\n    match /orgEvaluations/{id} {\n      allow read: if isAuthenticated();\n      allow write: if isHrAdmin() || isCeo();\n    }\n\n    // 개인 평가 (내부 구성원 모두 읽기 허용 - 팀장/임원/HR이 상호 조회 필요)\n    match /individualEvaluations/{id} {\n      allow read: if isAuthenticated();\n      allow write: if isAuthenticated() && (\n        (resource == null && request.resource.data.userId == request.auth.uid) ||\n        (resource != null && resource.data.userId == request.auth.uid) ||\n        isLead() || isExec() || isCeo() || isHrAdmin()\n      );\n    }\n\n    // 자기평가 (docId = userId_year 형태)\n    match /selfEvaluations/{docId} {\n      allow read: if isAuthenticated() && (\n        docId.matches('^' + request.auth.uid + '_.*') ||\n        isLead() || isExec() || isCeo() || isHrAdmin()\n      );\n      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;\n      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;\n    }\n\n    // 평가 사이클\n    match /evaluationCycles/{id} {\n      allow read: if isAuthenticated();\n      allow write: if isHrAdmin();\n    }\n\n    // 등급 쿼터\n    match /gradeQuotas/{id} {\n      allow read: if isAuthenticated();\n      allow write: if isHrAdmin();\n    }\n\n    // 연간 목표 (회사/조직)\n    match /annualGoals/{id} {\n      allow read: if isAuthenticated();\n      allow write: if isHrAdmin();\n    }\n\n    // 마일리지\n    match /mileages/{userId} {\n      allow read: if isAuthenticated() && (\n        isOwner(userId) || isHrAdmin() || isCeo()\n      );\n      allow write: if isHrAdmin() || isCeo();\n    }\n\n    // 1on1 Q&A 서브컬렉션\n    match /oneOnOnes/{id}/questions/{qId} {\n      allow read: if isAuthenticated();\n      allow create: if isAuthenticated();\n      allow update: if isAuthenticated();\n    }\n\n    // 부문/공장 등급 변경 이력\n    match /orgGradeHistories/{id} {\n      allow read: if isAuthenticated();\n      allow create: if isCeo();\n    }\n\n    // 부문/공장별 개인 등급 쿼터\n    match /divisionGradeQuotas/{id} {\n      allow read: if isAuthenticated();\n      allow write: if isHrAdmin() || isCeo();\n    }\n\n    // 초대 토큰 (토큰을 아는 사람만 읽기 가능 - UUID가 보안 역할)\n    match /invitations/{token} {\n      allow read: if true;\n      allow create: if isHrAdmin() || isCeo();\n      allow update: if true; // 초대 수락 시 usedAt 업데이트\n    }\n  }\n}\n"}]}}
